# Application Configuration
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_DOMAIN=yourdomain.com

# Supabase Configuration (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_supabase_service_role_key

# Google OAuth (for Supabase Auth - Production)
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Google Drive OAuth Configuration (Production)
GOOGLE_DRIVE_CLIENT_ID=your_production_google_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_production_google_drive_client_secret

# Microsoft Entra ID OAuth Configuration (Production) — Sign-in with Microsoft + OneDrive/SharePoint
# connector, one app registration serves both (see connector-abstraction-document-lifecycle.md Phase 1a)
MICROSOFT_CLIENT_ID=your_production_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_production_microsoft_client_secret
MICROSOFT_TENANT_ID=your_production_microsoft_tenant_id
# "Continue with Microsoft" button — keep false in production until publisher verification is
# resolved (blocked: current app registered under a personal MS account, can never be verified
# as-is — see plan). Flip to true once re-registered under a proper work-account tenant + verified.
MICROSOFT_SIGNIN_ENABLED=false

# Database Configuration (Production)
DATABASE_URL="postgresql://username:password@host:port/database"

# Node Environment (automatically set by deployment platform)
NODE_ENV=production

# Google Analytics Configuration (Production)
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here

# Optional: OpenAI API Key for Supabase AI features
# OPENAI_API_KEY=your_openai_api_key_here
